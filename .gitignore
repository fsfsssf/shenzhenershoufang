# ============================================================
# Git 忽略规则配置
# ============================================================

# ------------------------------
# Python 相关
# ------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.python-version
.venv/
venv/
env/

# ------------------------------
# 环境变量（包含敏感信息）
# ------------------------------
.env
.env.local
.env.development.local
.env.production.local

# ------------------------------
# 调试日志目录
# ------------------------------
skill_debug_logs/
http_client_debug/

# ------------------------------
# IDE 配置
# ------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ------------------------------
# Docker 相关
# ------------------------------
docker-compose.override.yml
.dockerignore

# ------------------------------
# 测试和覆盖率
# ------------------------------
.coverage
htmlcov/
.pytest_cache/
.tox/

# ------------------------------
# 构建产物
# ------------------------------
dist/
build/
*.egg-info/

# ------------------------------
# 临时文件
# ------------------------------
*.log
*.tmp
.cache/
